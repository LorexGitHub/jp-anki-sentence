# Default: Tencent Hy-MT2 (multilingual, strong Japanese) — auto-downloads on first generate (~4 GB)
LLM_PROVIDER=huggingface
HF_MODEL_ID=tencent/Hy-MT2-1.8B
HF_MAX_NEW_TOKENS=256
HF_PRELOAD_ON_STARTUP=true

# Faster TTS on Windows (skip Edge 403 issues)
TTS_PREFER_GTTS=true

# Other HF models:
# HF_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
# HF_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# LM Studio (set LLM_PROVIDER=openai_compatible)
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://127.0.0.1:1234/v1
# LLM_MODEL=local-model

# Ollama (only if `ollama` CLI works)
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:7b

TTS_VOICE=ja-JP-NanamiNeural
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
